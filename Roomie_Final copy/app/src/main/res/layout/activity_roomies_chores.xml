<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:gravity="top|center"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chores"
        android:textSize="50sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:fontFamily="serif"
        android:layout_marginTop="30dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="40dp"/>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="left">

        <CheckBox
            android:id="@+id/clean_toilet_checkbox"
            android:layout_width="278dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="70dp"
            android:background="@color/rooomies_Pink"
            android:text="Clean Toilet"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:textSize="40sp" />

        <CheckBox
            android:id="@+id/clean_shower_checkbox"
            android:layout_width="290dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="70dp"
            android:background="@color/rooomies_Pink"
            android:text="Clean Shower"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:textSize="40sp" />

        <CheckBox
            android:id="@+id/mop_floor_checkbox"
            android:layout_width="285dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="70dp"
            android:background="@color/rooomies_Pink"
            android:text="Mop Floor"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:textSize="40sp" />

        <CheckBox
            android:id="@+id/take_out_trash_checkbox"
            android:layout_width="313dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="220dp"
            android:background="@color/rooomies_Pink"
            android:text="Take out Trash"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:textSize="40sp" />
    </LinearLayout>

    <!-- Navigation bar at the bottom of the screen -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="bottom">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/rooomies_Blue"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/rooomies_Blue">

            <ImageButton
                android:layout_width="0dp"
                android:layout_height="124dp"
                android:layout_weight="1"
                android:background="@color/rooomies_Blue"
                android:src="@drawable/home_icon"
                android:contentDescription="Home" />

            <ImageButton
                android:layout_width="0dp"
                android:layout_height="124dp"
                android:layout_weight="1"
                android:background="@color/rooomies_Blue"
                android:src="@drawable/lists_icon"
                android:contentDescription="Lists" />

            <ImageButton
                android:layout_width="0dp"
                android:layout_height="124dp"
                android:layout_weight="1"
                android:background="@color/rooomies_Blue"
                android:src="@drawable/calendar_icon"
                android:contentDescription="Calendar" />

            <ImageButton
                android:layout_width="0dp"
                android:layout_height="124dp"
                android:layout_weight="1"
                android:background="@color/rooomies_Blue"
                android:src="@drawable/chores_icon"
                android:contentDescription="Chores" />

            <ImageButton
                android:layout_width="0dp"
                android:layout_height="124dp"
                android:layout_weight="1"
                android:background="@color/rooomies_Blue"
                android:src="@drawable/requests_icon"
                android:contentDescription="Requests" />

        </LinearLayout>


    </LinearLayout>
    <Button
        android:id="@+id/add_checkbox_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Checkbox"
        android:onClick="onAddCheckboxClicked"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="20dp"
        android:background="@color/rooomies_Pink"/>

</LinearLayout>
